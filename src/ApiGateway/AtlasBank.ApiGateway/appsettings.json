{
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4200",
      "http://localhost:5173"
    ]
  },
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/atlas-bank",
    "Audience": "atlas-bank-app"
  },
  "ReverseProxy": {
    "Routes": {
      "customers-route": {
        "ClusterId": "customers-cluster",
        "Match": {
          "Path": "/api/customers/{**catch-all}"
        }
      },
      "accounts-route": {
        "ClusterId": "accounts-cluster",
        "Match": {
          "Path": "/api/accounts/{**catch-all}"
        }
      },
      "transactions-route": {
        "ClusterId": "transactions-cluster",
        "Match": {
          "Path": "/api/transactions/{**catch-all}"
        }
      },
      "ledger-route": {
        "ClusterId": "ledger-cluster",
        "Match": {
          "Path": "/api/ledger/{**catch-all}"
        }
      },
      "cards-route": {
        "ClusterId": "cards-cluster",
        "Match": {
          "Path": "/api/cards/{**catch-all}"
        }
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "statements-route": {
        "ClusterId": "statements-cluster",
        "Match": {
          "Path": "/api/statements/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "customers-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://customer-service:8080"
          }
        }
      },
      "accounts-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://account-service:8080"
          }
        }
      },
      "transactions-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://transaction-service:8080"
          }
        }
      },
      "ledger-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://ledger-service:8080"
          }
        }
      },
      "cards-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://card-service:8080"
          }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://notification-service:8080"
          }
        }
      },
      "statements-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://statement-service:8080"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*"
}
